# =============================================================================
# ByBot App — Variables de entorno (plantilla)
# Copia este archivo a .env y ajusta los valores:
#     cp .env.example .env
# =============================================================================

# --------- Aplicación ---------
APP_NAME="ByBot App"
APP_ENV=development            # valores: development, production
APP_DEBUG=true                 # valores: true, false
APP_URL=http://localhost/projects/bybot_v1
APP_TIMEZONE=America/Bogota

# --------- Base de datos ---------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=bybot_consolidado
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# --------- Almacenamiento de archivos ---------
STORAGE_DRIVER=local          # valores: local, remote (remote pendiente)
UPLOAD_DIR=uploads            # carpeta relativa a la raíz del proyecto
UPLOAD_MAX_SIZE_IMAGE=5242880     # 5 MB
UPLOAD_MAX_SIZE_PDF=10485760      # 10 MB
UPLOAD_MAX_SIZE_HTML=2097152      # 2 MB
UPLOAD_MAX_SIZE_EXCEL=10485760    # 10 MB
UPLOAD_ALLOWED_MIMES=application/pdf,image/jpeg,image/png,text/html,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet

# Storage remoto (placeholder — se activa con STORAGE_DRIVER=remote)
REMOTE_STORAGE_TYPE=s3        # valores: s3, b2, r2
REMOTE_STORAGE_BUCKET=
REMOTE_STORAGE_KEY=
REMOTE_STORAGE_SECRET=
REMOTE_STORAGE_REGION=
REMOTE_STORAGE_ENDPOINT=

# --------- Sesiones ---------
SESSION_LIFETIME=28800        # 8 horas en segundos
SESSION_COOKIE=bybot_sess
SESSION_SECURE=false          # true en producción con HTTPS

# --------- Seguridad ---------
APP_KEY=                     # cadena aleatoria de 32+ chars (openssl rand -hex 32)
API_RATE_LIMIT=100            # peticiones por minuto por token/IP
N8N_ACCESS_TOKEN=             # legacy: token compartido con workers externos (no usado hoy)

# --------- IA (Gemini) — usado por app_worker ---------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TEMPERATURE=0.1
GEMINI_MAX_TOKENS=4000

# --------- Worker Python ---------
WORKER_PY_BIN=python3
WORKER_TIMEOUT_SEG=120

# --------- Logging ---------
LOG_LEVEL=debug               # valores: debug, info, warning, error, critical
LOG_DIR=logs