# ================= ByBot App — Variables de entorno (único .env) =================
# Copia este archivo a .env y ajusta:
#     cp .env.example .env
# Prefijos por servicio: BACKEND_, FRONTEND_, BOTSTORAGE_ ; compartidas: DB_, GEMINI_, ...

# ---------------- App general ----------------
APP_NAME="ByBot App"
APP_ENV=development                  # development | production
APP_DEBUG=true
APP_TIMEZONE=America/Bogota

# ---------------- Base de datos (MariaDB / MySQL) ----------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=bybot_consolidado
DB_USER=root
DB_PASS=

# Conexión Prisma (backend). FORMATO mysql://USER:PASS@HOST:PORT/DB
DATABASE_URL=mysql://USUARIO:PASSWORD@127.0.0.1:3306/bybot_consolidado

# ---------------- Backend (Fastify :3001) ----------------
BACKEND_HOST=127.0.0.1
BACKEND_PORT=3001
BACKEND_BASE_URL=http://localhost:3001
BACKEND_LOG_LEVEL=debug             # trace|debug|info|warn|error|fatal
BACKEND_JWT_SECRET=cambia_esta_clave_por_una_larga_aleatoria  # openssl rand -hex 32
BACKEND_JWT_ACCESS_TTL=15m
BACKEND_JWT_REFRESH_TTL=7d
BACKEND_RATE_LIMIT=100              # peticiones por minuto
# Cliente interno hacia botstorage
BACKEND_BOTSTORAGE_URL=http://localhost:3002
BACKEND_BOTSTORAGE_TOKEN=cambia_token_interno_compartido

# ---------------- Frontend (Vite :5173) ----------------
FRONTEND_PORT=5173
FRONTEND_API_BASE=http://localhost:3001/api/v1
# Expuesto a Vite (debe empezar por VITE_)
VITE_API_BASE_URL=http://localhost:3001/api/v1

# ---------------- Botstorage (Fastify :3002) ----------------
BOTSTORAGE_HOST=127.0.0.1
BOTSTORAGE_PORT=3002
BOTSTORAGE_LOG_LEVEL=debug
BOTSTORAGE_INTERNAL_TOKEN=cambia_token_interno_compartido   # debe coincidir con BACKEND_BOTSTORAGE_TOKEN
# Driver de almacenamiento
STORAGE_DRIVER=local               # local | remote
STORAGE_LOCAL_DIR=uploads          # carpeta relativa a raíz del proyecto
# Storage remoto (placeholder — se activa con STORAGE_DRIVER=remote)
REMOTE_STORAGE_TYPE=s3              # s3 | b2 | r2
REMOTE_STORAGE_BUCKET=
REMOTE_STORAGE_KEY=
REMOTE_STORAGE_SECRET=
REMOTE_STORAGE_REGION=
REMOTE_STORAGE_ENDPOINT=

# ---------------- Subida de archivos ----------------
UPLOAD_MAX_SIZE_IMAGE=5242880      # 5 MB
UPLOAD_MAX_SIZE_PDF=10485760       # 10 MB
UPLOAD_MAX_SIZE_HTML=2097152       # 2 MB
UPLOAD_MAX_SIZE_EXCEL=10485760     # 10 MB
UPLOAD_ALLOWED_MIMES=application/pdf,image/jpeg,image/png,text/html,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet

# ---------------- IA Gemini (Fase 2 - usa botworker) ----------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TEMPERATURE=0.1
GEMINI_MAX_TOKENS=4000

# ---------------- Python worker (botworker + bots) ----------------
WORKER_PY_BIN=python3
WORKER_TIMEOUT_SEG=120